# mx-core 后端 base url（include /api/v2 与否，依后端而定；mx-core 默认根域）
VITE_APP_BASE_API=http://localhost:2333

# socket.io gateway。空则同 BASE_API origin。
# VITE_APP_GATEWAY=http://localhost:2333

# 公网展示前台 url（用于「访问站点」之类按钮）
# VITE_APP_WEB_URL=http://localhost:2323

# 登录页背景图
VITE_APP_LOGIN_BG=https://fastly.jsdelivr.net/gh/mx-space/docs-images@master/images/chichi-1.jpeg

# CDN 静态资源前缀（极少需要）
# VITE_APP_PUBLIC_URL=https://fastly.jsdelivr.net/gh/mx-space/admin-next@gh-pages/
